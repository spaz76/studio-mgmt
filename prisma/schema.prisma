// Atnachta Studio Management — Prisma Schema
// Multi-tenant SaaS — Phase 2 (Full Schema)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  OPERATOR
  VIEWER
}

enum Permission {
  createWorkshop
  editWorkshop
  deleteWorkshop
  manageBookings
  createProduct
  editProduct
  updateProductStock
  createMaterial
  consumeMaterial
  updatePaymentStatus
  viewReports
  exportReports
  manageUsers
  changePlan
  editStudioSettings
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum WorkshopStatus {
  draft
  open
  pending_minimum
  confirmed
  full
  cancelled
  postponed
  completed
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  waitlist
}

enum PaymentStatus {
  pending
  paid
  partial
  refunded
  cancelled
}

enum ReminderStatus {
  open
  in_progress
  done
}

enum ReminderType {
  workshop
  seasonal
  material
  manual
}

enum StockLogAction {
  ordered
  purchase
  consumption
  adjustment
  loss
}

enum WorkshopType {
  REGULAR
  RECURRING
  CLASS
  SEASONAL
  EVENT
  PARENT_CHILD
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum EventPricingModel {
  FLAT
  PER_PARTICIPANT
  PACKAGE
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum TaskUrgency {
  HIGH
  NORMAL
  LOW
}

// ─────────────────────────────────────────────
// STUDIO
// ─────────────────────────────────────────────

model Studio {
  id                   String   @id @default(cuid())
  name                 String
  publicName           String
  slug                 String   @unique
  logoUrl              String?
  primaryColor         String?
  secondaryColor       String?
  contactEmail         String?
  contactPhone         String?
  address              String?
  planType             PlanType @default(FREE)
  maxUsers             Int      @default(5)
  maxWorkshopsPerMonth Int      @default(20)
  maxProducts          Int      @default(100)
  vatRate              Decimal  @default(18.0) @db.Decimal(5, 2)
  pricesIncludeVat     Boolean  @default(true)

  // Visual Identity
  fontFamily           String?
  fontSize             String?  @default("medium")

  // Contact & Links
  websiteUrl           String?
  facebookUrl          String?
  instagramUrl         String?
  reviewsUrl           String?
  phoneNumber          String?
  whatsappNumber       String?
  hasOwnWebsite        Boolean  @default(false)

  // Payment integration
  paymentUrl           String?  // external payment link (Morning/bit/PayBox)

  // Invitation settings
  inviteChannel        String?  @default("both") // email, whatsapp, both

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members           StudioMember[]
  customers         Customer[]
  workshopTemplates WorkshopTemplate[]
  workshopEvents    WorkshopEvent[]
  bookings          Booking[]
  payments          Payment[]
  products          Product[]
  productVariants   ProductVariant[]
  suppliers         Supplier[]
  materials         Material[]
  materialStockLogs MaterialStockLog[]
  reminders         Reminder[]
  messageTemplates  MessageTemplate[]
  tasks             Task[]
  integrations      StudioIntegration[]
  kilns             Kiln[]
  firings           Firing[]
  firingTypes       FiringType[]
  punchCards        PunchCard[]
  categories        Category[]
  attendances       Attendance[]
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  studioMemberships StudioMember[]
  workshopEvents    WorkshopEvent[]    @relation("WorkshopCreatedBy")
  materialStockLogs MaterialStockLog[]
  remindersCreated  Reminder[]         @relation("ReminderCreatedBy")
  remindersAssigned Reminder[]         @relation("ReminderAssignedTo")
}

// ─────────────────────────────────────────────
// STUDIO MEMBERSHIP & PERMISSIONS
// ─────────────────────────────────────────────

model StudioMember {
  id                 String       @id @default(cuid())
  studioId           String
  userId             String
  role               Role
  extraPermissions   Permission[]
  revokedPermissions Permission[]
  isActive           Boolean      @default(true)
  invitedAt          DateTime     @default(now())
  joinedAt           DateTime?

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studioId, userId])
  @@index([studioId])
}

// ─────────────────────────────────────────────
// NEXT-AUTH REQUIRED TABLES
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id                     String   @id @default(cuid())
  studioId               String
  name                   String
  email                  String?
  phone                  String?
  notes                  String?
  tags                   String[]
  preferredContactMethod String?  // email, phone, whatsapp, sms
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  studio     Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  punchCards PunchCard[]

  @@index([studioId])
  @@index([studioId, email])
}

// ─────────────────────────────────────────────
// WORKSHOP TEMPLATES
// ─────────────────────────────────────────────

model WorkshopTemplate {
  id              String        @id @default(cuid())
  studioId        String
  name            String
  description     String?
  durationMinutes Int           @default(120)
  minParticipants Int           @default(1)
  maxParticipants Int           @default(12)
  defaultPrice    Decimal       @default(0) @db.Decimal(10, 2)
  tags            String[]
  isActive        Boolean       @default(true)

  // Advanced: Workshop Type
  workshopType    WorkshopType  @default(REGULAR)

  // Advanced: Recurrence (RECURRING)
  recurrenceFrequency  RecurrenceFrequency?
  recurrenceDayOfWeek  Int?    // 0=Sunday … 6=Saturday
  recurrenceStartTime  String? // HH:mm
  recurrenceEndTime    String? // HH:mm

  // Advanced: Seasonal (SEASONAL)
  seasonStartMonth             Int?   // 1–12
  seasonEndMonth               Int?   // 1–12
  seasonReminderDays           Int[]
  seasonPublishLeadDays        Int?
  seasonPrepLeadDays           Int?
  seasonOpenRegistrationDays   Int?
  seasonCloseRegistrationDays  Int?

  // Advanced: Class (CLASS)
  totalSessions Int?

  // Advanced: Event (EVENT)
  eventContactName     String?
  eventContactPhone    String?
  eventSpecialRequests String?
  eventPricingModel    EventPricingModel?

  // Advanced: Parent-Child (PARENT_CHILD)
  ageRangeMin              Int?
  ageRangeMax              Int?
  requiresAdultSupervision Boolean @default(true)

  // Phase B: Marketing & sharing
  marketingText   String?
  internalNotes   String?
  registrationUrl String?

  // Phase B: Lifecycle
  isArchived Boolean @default(false)
  usageCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio           Studio            @relation(fields: [studioId], references: [id], onDelete: Cascade)
  workshopEvents   WorkshopEvent[]
  packageLineItems PackageLineItem[]
  images           TemplateImage[]
  punchCards       PunchCard[]

  @@index([studioId])
  @@index([studioId, isArchived])
}

// ─────────────────────────────────────────────
// TEMPLATE IMAGES
// ─────────────────────────────────────────────

model TemplateImage {
  id         String  @id @default(cuid())
  templateId String
  url        String
  alt        String?
  isPrimary  Boolean @default(false)
  sortOrder  Int     @default(0)

  template WorkshopTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ─────────────────────────────────────────────
// WORKSHOP EVENTS
// ─────────────────────────────────────────────

model WorkshopEvent {
  id                   String         @id @default(cuid())
  studioId             String
  templateId           String?
  title                String
  description          String?
  startsAt             DateTime
  endsAt               DateTime
  status               WorkshopStatus @default(draft)
  minParticipants      Int            @default(1)
  maxParticipants      Int            @default(12)
  price                Decimal        @default(0) @db.Decimal(10, 2)
  location             String?
  googleCalendarEventId String?
  notes                String?
  createdById          String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  studio           Studio            @relation(fields: [studioId], references: [id], onDelete: Cascade)
  template         WorkshopTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("WorkshopCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  bookings         Booking[]
  reminders        Reminder[]
  packageLineItems PackageLineItem[]

  @@index([studioId])
  @@index([studioId, status])
  @@index([studioId, startsAt])
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  studioId         String
  workshopEventId  String
  customerId       String
  participantCount Int           @default(1)
  status           BookingStatus @default(pending)
  notes            String?
  publicToken      String        @unique @default(cuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  studio        Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  workshopEvent WorkshopEvent @relation(fields: [workshopEventId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  payments      Payment[]
  attendance    Attendance?

  @@index([studioId])
  @@index([workshopEventId])
  @@index([customerId])
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id        String        @id @default(cuid())
  studioId  String
  bookingId String
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(pending)
  notes     String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  studio  Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([bookingId])
  @@index([studioId, status])
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  studioId    String
  name        String
  description String?
  skuBase     String
  category    String?
  categoryId  String?
  imageUrl    String?
  purchaseUrl String?
  isSeasonal  Boolean  @default(false)
  seasonStart Int?     // month number 1–12
  seasonEnd   Int?     // month number 1–12
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio       Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  variants     ProductVariant[]
  categoryRef  Category?        @relation("ProductCategory", fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([studioId, skuBase])
  @@index([studioId])
  @@index([studioId, category])
  @@index([categoryId])
}

// ─────────────────────────────────────────────
// PRODUCT VARIANTS
// ─────────────────────────────────────────────

model ProductVariant {
  id                String   @id @default(cuid())
  studioId          String
  productId         String
  name              String
  sku               String   @unique
  price             Decimal  @default(0) @db.Decimal(10, 2)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  barcode           String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  studio  Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────

model Supplier {
  id          String   @id @default(cuid())
  studioId    String
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio            Studio             @relation(fields: [studioId], references: [id], onDelete: Cascade)
  materialSuppliers MaterialSupplier[]
  contacts          SupplierContact[]

  @@index([studioId])
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  role       String?
  phone      String?
  extension  String?
  email      String?
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

// ─────────────────────────────────────────────
// MATERIALS
// ─────────────────────────────────────────────

model Material {
  id                String   @id @default(cuid())
  studioId          String
  name              String
  description       String?
  unit              String   @default("יחידה")
  stockQuantity     Decimal  @default(0) @db.Decimal(10, 3)
  lowStockThreshold Decimal  @default(5) @db.Decimal(10, 3)
  orangeThreshold   Decimal  @default(10) @db.Decimal(10, 3)
  redThreshold      Decimal  @default(3) @db.Decimal(10, 3)
  barcode           String?
  notes             String?
  categoryId        String?
  purchaseUrl       String?
  pricePerUnit      Decimal? @db.Decimal(10, 2)
  pricePerPackage   Decimal? @db.Decimal(10, 2)
  packageSize       String?
  width             String?
  height            String?
  minTemp           Int?
  maxTemp           Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  studio            Studio             @relation(fields: [studioId], references: [id], onDelete: Cascade)
  materialSuppliers MaterialSupplier[]
  stockLogs         MaterialStockLog[]
  reminders         Reminder[]
  categoryRef       Category?          @relation("MaterialCategory", fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([categoryId])
}

// ─────────────────────────────────────────────
// MATERIAL <-> SUPPLIER (join with extra data)
// ─────────────────────────────────────────────

model MaterialSupplier {
  id           String   @id @default(cuid())
  materialId   String
  supplierId   String
  pricePerUnit Decimal? @db.Decimal(10, 2)
  isPreferred  Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([materialId, supplierId])
  @@index([materialId])
  @@index([supplierId])
}

// ─────────────────────────────────────────────
// MATERIAL STOCK LOG
// ─────────────────────────────────────────────

model MaterialStockLog {
  id           String         @id @default(cuid())
  studioId     String
  materialId   String
  action       StockLogAction
  quantity     Decimal        @db.Decimal(10, 3)
  notes        String?
  performedById String?
  createdAt    DateTime       @default(now())

  studio      Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  performedBy User?    @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([materialId])
}

// ─────────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────────

model Reminder {
  id                    String         @id @default(cuid())
  studioId              String
  title                 String
  body                  String?
  status                ReminderStatus @default(open)
  type                  ReminderType   @default(manual)
  dueAt                 DateTime?
  createdById           String?
  assignedToId          String?
  relatedWorkshopEventId String?
  relatedMaterialId     String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  studio               Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdBy            User?          @relation("ReminderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo           User?          @relation("ReminderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  relatedWorkshopEvent WorkshopEvent? @relation(fields: [relatedWorkshopEventId], references: [id], onDelete: SetNull)
  relatedMaterial      Material?      @relation(fields: [relatedMaterialId], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([studioId, status])
  @@index([studioId, dueAt])
}

// ─────────────────────────────────────────────
// PACKAGE LINE ITEMS
// ─────────────────────────────────────────────

model PackageLineItem {
  id              String   @id @default(cuid())
  templateId      String?
  workshopEventId String?
  description     String
  amount          Decimal  @db.Decimal(10, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  template      WorkshopTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workshopEvent WorkshopEvent?    @relation(fields: [workshopEventId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([workshopEventId])
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model Attendance {
  id          String    @id @default(cuid())
  studioId    String
  bookingId   String
  attended    Boolean   @default(false)
  markedAt    DateTime?
  punchCardId String?
  notes       String?
  createdAt   DateTime  @default(now())

  studio    Studio     @relation(fields: [studioId], references: [id], onDelete: Cascade)
  booking   Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  punchCard PunchCard? @relation(fields: [punchCardId], references: [id], onDelete: SetNull)

  @@unique([bookingId])
  @@index([studioId])
  @@index([bookingId])
}

// ─────────────────────────────────────────────
// PUNCH CARDS
// ─────────────────────────────────────────────

model PunchCard {
  id            String    @id @default(cuid())
  studioId      String
  customerId    String
  templateId    String?
  totalSessions Int
  usedSessions  Int       @default(0)
  paidAmount    Decimal   @default(0) @db.Decimal(10, 2)
  purchasedAt   DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studio      Studio            @relation(fields: [studioId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template    WorkshopTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attendances Attendance[]

  @@index([studioId])
  @@index([customerId])
}

// ─────────────────────────────────────────────
// MESSAGE TEMPLATES
// ─────────────────────────────────────────────

model MessageTemplate {
  id         String   @id @default(cuid())
  studioId   String
  type       String   // confirmation, reminder, thankyou, payment_reminder, feedback
  level      String   @default("studio") // studio, template, event
  templateId String?
  eventId    String?
  subject    String?
  body       String
  channel    String   // whatsapp, sms, email
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([studioId, type, channel])
}

// ─────────────────────────────────────────────
// TASKS (dashboard)
// ─────────────────────────────────────────────

enum TaskCategory {
  manual
  event
  product
  material
  payment
}

model Task {
  id                String       @id @default(cuid())
  studioId          String
  userId            String?
  title             String
  description       String?
  dueDate           DateTime?
  reminderDate      DateTime?
  category          TaskCategory @default(manual)
  status            TaskStatus   @default(NEW)
  urgency           TaskUrgency  @default(NORMAL)
  relatedId         String?
  relatedCustomerId String?
  relatedSupplierId String?
  completed         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([studioId, completed])
}

// ─────────────────────────────────────────────
// CATEGORIES (hierarchical)
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  studio    Studio     @relation(fields: [studioId], references: [id], onDelete: Cascade)
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  products  Product[]  @relation("ProductCategory")
  materials Material[] @relation("MaterialCategory")

  @@index([studioId])
  @@index([parentId])
}

// ─────────────────────────────────────────────
// KILNS
// ─────────────────────────────────────────────

model Kiln {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  type      String?  // electric, gas, wood, raku
  maxTemp   Int?
  capacity  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio      Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  firings     Firing[]
  firingTypes FiringType[]

  @@index([studioId])
}

model Firing {
  id             String      @id @default(cuid())
  kilnId         String
  studioId       String
  firingType     String      // bisque, glaze, raku, pit, custom
  targetTemp     Int?
  startedAt      DateTime?
  completedAt    DateTime?
  status         String      @default("planned") // planned, loading, firing, cooling, unloading, completed
  notes          String?
  firingTypeId   String?
  loadLevel      String?     // quarter/half/three_quarter/full
  estimatedEndAt DateTime?
  cooledAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  kiln           Kiln        @relation(fields: [kilnId], references: [id], onDelete: Cascade)
  studio         Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  firingTypePlan FiringType? @relation(fields: [firingTypeId], references: [id])

  @@index([kilnId])
  @@index([studioId])
  @@index([firingTypeId])
}

model FiringType {
  id        String        @id @default(cuid())
  kilnId    String
  kiln      Kiln          @relation(fields: [kilnId], references: [id], onDelete: Cascade)
  studioId  String
  studio    Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name      String
  stages    FiringStage[]
  firings   Firing[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([kilnId])
  @@index([studioId])
}

model FiringStage {
  id              String     @id @default(cuid())
  firingTypeId    String
  firingType      FiringType @relation(fields: [firingTypeId], references: [id], onDelete: Cascade)
  targetTemp      Int
  durationMinutes Int
  sortOrder       Int

  @@index([firingTypeId])
}

// ─────────────────────────────────────────────
// STUDIO INTEGRATIONS (Google Calendar etc.)
// ─────────────────────────────────────────────

model StudioIntegration {
  id           String   @id @default(cuid())
  studioId     String
  provider     String   // "google_calendar"
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  calendarId   String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@unique([studioId, provider])
  @@index([studioId])
}
